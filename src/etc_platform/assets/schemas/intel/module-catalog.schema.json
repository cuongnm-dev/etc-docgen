{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://etc-vn.github.io/schemas/intel/module-catalog.schema.json",
  "title": "Module Catalog",
  "description": "Logical bounded contexts for SDLC pipeline (M-NNN). Per ADR-003 D8.",
  "type": "object",
  "required": ["schema_version", "modules"],
  "properties": {
    "schema_version": { "type": "string" },
    "modules": {
      "type": "array",
      "items": { "$ref": "#/definitions/Module" }
    }
  },
  "definitions": {
    "Module": {
      "type": "object",
      "required": ["id", "name", "slug", "status"],
      "properties": {
        "id": { "type": "string", "pattern": "^M-[0-9]{3,}$" },
        "name": { "type": "string", "minLength": 3, "maxLength": 100 },
        "slug": { "type": "string", "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$" },
        "status": { "enum": ["proposed", "in-progress", "blocked", "done"] },
        "depends_on": {
          "type": "array",
          "items": { "type": "string", "pattern": "^M-[0-9]{3,}$" }
        },
        "feature_ids": {
          "type": "array",
          "items": { "type": "string", "pattern": "^F-[0-9]{3,}[a-z]?$" }
        },
        "primary_service": { "type": "string" },
        "modules_in_scope": {
          "type": "array",
          "description": "Source module IDs from doc-brief (e.g. M01-M20) — original numbering before SDLC dispatch unit assignment",
          "items": { "type": "string" }
        },
        "created_at": { "type": "string", "format": "date-time" },
        "tier": { "type": "string" },
        "mvp_wave": { "type": "integer" },
        "risk_score": { "type": "integer", "minimum": 1, "maximum": 5 },
        "agent_flags": { "type": "object" }
      }
    }
  }
}
