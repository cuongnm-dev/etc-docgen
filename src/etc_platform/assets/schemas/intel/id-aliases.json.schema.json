{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://etc-vn.github.io/schemas/intel/id-aliases.json.schema.json",
  "title": "ID aliases + reservations",
  "description": "Track legacy ID renames + intentional ID gaps. Per ADR-003 D10-1 + D10-6.",
  "type": "object",
  "required": ["schema_version"],
  "properties": {
    "schema_version": { "type": "string" },
    "id_renames": {
      "type": "array",
      "description": "Legacy ID → canonical ID mapping (e.g. F-061 pipeline → M-001 module migration)",
      "items": {
        "type": "object",
        "required": ["from", "to", "renamed_at"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "renamed_at": { "type": "string", "format": "date-time" },
          "reason": { "type": "string" },
          "by": { "type": "string" }
        }
      }
    },
    "slug_renames": {
      "type": "array",
      "description": "Module slug renames via rename_module_slug tool (D10-1)",
      "items": {
        "type": "object",
        "required": ["module_id", "old_slug", "new_slug", "renamed_at"],
        "properties": {
          "module_id": { "type": "string", "pattern": "^M-[0-9]{3,}$" },
          "old_slug": { "type": "string" },
          "new_slug": { "type": "string" },
          "renamed_at": { "type": "string", "format": "date-time" },
          "reason": { "type": "string" }
        }
      }
    },
    "reservations": {
      "type": "array",
      "description": "Intentional ID gaps (D10-6 — verify_id_uniqueness severity tier helper)",
      "items": {
        "type": "object",
        "required": ["range", "reason"],
        "properties": {
          "range": {
            "type": "string",
            "description": "ID range, e.g. F-061..F-080",
            "pattern": "^[FMH]-[0-9]+\\.\\.[FMH]-[0-9]+$"
          },
          "reason": { "type": "string" },
          "reserved_by": { "type": "string" },
          "expires": {
            "type": ["string", "null"],
            "description": "ISO date or null for indefinite"
          }
        }
      }
    }
  }
}
