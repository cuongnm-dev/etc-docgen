{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://etc-vn.github.io/schemas/intel/feature-catalog.schema.json",
  "title": "Feature Catalog",
  "description": "Business features (F-NNN) with module ownership + cross-cutting tracking. Per ADR-003 D8 + D10-2.",
  "type": "object",
  "required": ["schema_version", "features"],
  "properties": {
    "schema_version": { "type": "string" },
    "multi_role": { "type": "boolean" },
    "roles": { "type": "array", "items": { "type": "string" } },
    "services": { "type": "array", "items": { "type": "object" } },
    "features": {
      "type": "array",
      "items": { "$ref": "#/definitions/Feature" }
    }
  },
  "definitions": {
    "Feature": {
      "type": "object",
      "required": ["id", "module_id"],
      "properties": {
        "id": { "type": "string", "pattern": "^F-[0-9]{3,}[a-z]?$" },
        "module_id": {
          "type": "string",
          "pattern": "^M-[0-9]{3,}$",
          "description": "Primary owner module (FK to module-catalog.modules[].id). Per ADR-003 D8 — required after refactor."
        },
        "consumed_by_modules": {
          "type": "array",
          "description": "Cross-cutting tracking (D10-2): modules consuming this feature beyond primary owner. verify_cross_references checks this matches code dependencies.",
          "items": { "type": "string", "pattern": "^M-[0-9]{3,}$" }
        },
        "name": { "type": "string" },
        "slug": { "type": "string", "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$" },
        "status": { "enum": ["proposed", "in-progress", "blocked", "done"] },
        "priority": { "enum": ["critical", "high", "medium", "low"] },
        "description": { "type": "string", "minLength": 200 },
        "business_intent": { "type": "string", "minLength": 100 },
        "flow_summary": { "type": "string", "minLength": 150 },
        "acceptance_criteria": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 3
        },
        "entities": { "type": "array" },
        "business_rules": { "type": "array" },
        "roles": { "type": "array" },
        "in_scope": { "type": "array", "items": { "type": "string" } },
        "out_of_scope": { "type": "array", "items": { "type": "string" } },
        "implementation_evidence": { "type": "object" },
        "test_evidence_ref": { "type": "string" },
        "mvp_wave": { "type": "integer" },
        "risk_score": { "type": "integer", "minimum": 1, "maximum": 5 },
        "phase": { "type": "string" },
        "testing_strategy": { "type": "object" },
        "migration_strategy": { "type": "object" },
        "evidence": { "type": "array" }
      }
    }
  }
}
