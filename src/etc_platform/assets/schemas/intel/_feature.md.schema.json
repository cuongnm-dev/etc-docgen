{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://etc-vn.github.io/schemas/intel/_feature.md.schema.json",
  "title": "_feature.md frontmatter schema",
  "description": "Feature spec card. Created by from-doc/from-code/new-feature. Body sections free-form. Per ADR-003 D8.",
  "type": "object",
  "required": ["feature-id", "feature-name", "module-id", "status", "slug"],
  "properties": {
    "feature-id": { "type": "string", "pattern": "^F-[0-9]{3,}[a-z]?$" },
    "feature-name": { "type": "string", "minLength": 3 },
    "slug": { "type": "string", "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$" },
    "module-id": { "type": "string", "pattern": "^M-[0-9]{3,}$" },
    "status": { "enum": ["proposed", "in-progress", "blocked", "done"] },
    "priority": { "enum": ["critical", "high", "medium", "low"] },
    "consumed_by_modules": {
      "type": "array",
      "description": "Cross-cutting tracking per D10-2",
      "items": { "type": "string", "pattern": "^M-[0-9]{3,}$" }
    },
    "locked-fields": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Fields immutable for skill Edit (D10-3)"
    },
    "created": { "type": "string" },
    "last-updated": { "type": "string" }
  }
}
