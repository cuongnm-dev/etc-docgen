{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://etc-vn.github.io/schemas/intel/implementations.yaml.schema.json",
  "title": "Implementations mapping (logical → physical)",
  "description": "Maps module/feature to apps/services/libs. Per ADR-003 D8 (loose coupling docs ↔ code).",
  "oneOf": [
    { "$ref": "#/definitions/ModuleImplementations" },
    { "$ref": "#/definitions/FeatureImplementations" },
    { "$ref": "#/definitions/HotfixImplementations" }
  ],
  "definitions": {
    "ModuleImplementations": {
      "type": "object",
      "required": ["module_id", "type"],
      "properties": {
        "module_id": { "type": "string", "pattern": "^M-[0-9]{3,}$" },
        "module_name": { "type": "string" },
        "type": { "const": "bounded-context" },
        "slug": { "type": "string" },
        "implementations": {
          "type": "object",
          "properties": {
            "apps": { "type": "array", "items": { "$ref": "#/definitions/ImplRef" } },
            "services": { "type": "array", "items": { "$ref": "#/definitions/ImplRef" } },
            "libs": { "type": "array", "items": { "$ref": "#/definitions/ImplRef" } },
            "packages": { "type": "array", "items": { "$ref": "#/definitions/ImplRef" } }
          }
        },
        "stakeholders": {
          "type": "object",
          "properties": {
            "business-owner": { "type": "string" },
            "tech-lead": { "type": "string" },
            "qa-lead": { "type": "string" }
          }
        },
        "depends_on": {
          "type": "array",
          "items": { "type": "string", "pattern": "^M-[0-9]{3,}$" }
        }
      }
    },
    "FeatureImplementations": {
      "type": "object",
      "required": ["feature_id", "module_id"],
      "properties": {
        "feature_id": { "type": "string", "pattern": "^F-[0-9]{3,}[a-z]?$" },
        "module_id": { "type": "string", "pattern": "^M-[0-9]{3,}$" },
        "slug": { "type": "string" },
        "implementations": {
          "type": "object",
          "properties": {
            "primary": {
              "type": "string",
              "description": "Path to primary code location, e.g. services/iam-service/internal/vneid"
            },
            "consumers": { "type": "array", "items": { "type": "string" } }
          }
        },
        "consumed_by_modules": {
          "type": "array",
          "items": { "type": "string", "pattern": "^M-[0-9]{3,}$" }
        }
      }
    },
    "HotfixImplementations": {
      "type": "object",
      "required": ["hotfix_id", "affected_modules"],
      "properties": {
        "hotfix_id": { "type": "string", "pattern": "^H-[0-9]{3,}$" },
        "slug": { "type": "string" },
        "affected_modules": {
          "type": "array",
          "items": { "type": "string", "pattern": "^M-[0-9]{3,}$" }
        },
        "patches": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "file": { "type": "string" },
              "module_id": { "type": "string", "pattern": "^M-[0-9]{3,}$" },
              "lines": { "type": "string" },
              "rationale": { "type": "string" }
            }
          }
        }
      }
    },
    "ImplRef": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "path": {
          "type": "string",
          "description": "Path relative to workspace root, e.g. services/iam-service"
        },
        "role": {
          "enum": ["primary", "secondary", "consumer", "shared-contract", "shared"]
        },
        "owns": { "type": "array", "items": { "type": "string" } },
        "consumes": { "type": "array", "items": { "type": "string" } },
        "provides": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
