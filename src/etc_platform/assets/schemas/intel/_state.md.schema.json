{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://etc-vn.github.io/schemas/intel/_state.md.schema.json",
  "title": "_state.md frontmatter schema",
  "description": "SDLC state machine. Discriminator on pipeline-type: sdlc | hotfix. Per ADR-003 D1-D8.",
  "oneOf": [
    { "$ref": "#/definitions/ModuleState" },
    { "$ref": "#/definitions/HotfixState" }
  ],
  "definitions": {
    "ModuleState": {
      "type": "object",
      "required": [
        "feature-id",
        "feature-name",
        "pipeline-type",
        "status",
        "current-stage",
        "docs-path",
        "intel-path",
        "stages-queue",
        "repo-type"
      ],
      "properties": {
        "feature-id": {
          "type": "string",
          "pattern": "^M-[0-9]{3,}$",
          "description": "Module ID. Field name 'feature-id' kept for backward-compat with Cursor resume-feature parser."
        },
        "feature-name": { "type": "string" },
        "pipeline-type": { "const": "sdlc" },
        "status": { "enum": ["proposed", "in-progress", "blocked", "done"] },
        "current-stage": { "type": "string" },
        "docs-path": { "type": "string" },
        "intel-path": { "const": "docs/intel" },
        "stages-queue": { "type": "array", "items": { "type": "string" } },
        "depends-on": {
          "type": "array",
          "items": { "type": "string", "pattern": "^M-[0-9]{3,}$" }
        },
        "blocked-by": { "type": "array" },
        "completed-stages": { "type": "object" },
        "kpi": { "type": "object" },
        "rework-count": { "type": "object" },
        "locked-fields": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Fields immutable for skill Edit (D10-3 enforcement)"
        },
        "agent-flags": { "type": "object" },
        "feature-req": { "type": "string" },
        "clarification-notes": { "type": "string" },
        "created": { "type": "string" },
        "last-updated": { "type": "string" },
        "output-mode": { "enum": ["lean", "full"] },
        "repo-type": { "enum": ["mini", "mono"] },
        "repo-path": { "type": "string" },
        "project": { "type": "string" },
        "worktree-path": { "type": "string" },
        "worktree-branch": { "type": "string" },
        "worktree-base": { "type": "string" }
      }
    },
    "HotfixState": {
      "type": "object",
      "required": [
        "feature-id",
        "feature-name",
        "pipeline-type",
        "is-hotfix",
        "status",
        "severity",
        "current-stage",
        "docs-path",
        "stages-queue"
      ],
      "properties": {
        "feature-id": { "type": "string", "pattern": "^H-[0-9]{3,}$" },
        "feature-name": { "type": "string" },
        "pipeline-type": { "const": "hotfix" },
        "is-hotfix": { "const": true },
        "status": { "enum": ["in-progress", "blocked", "done"] },
        "severity": { "enum": ["critical", "high", "medium"] },
        "current-stage": { "type": "string" },
        "docs-path": { "type": "string" },
        "intel-path": { "const": "docs/intel" },
        "stages-queue": { "type": "array" },
        "skipped-stages": {
          "type": "array",
          "items": { "enum": ["ba", "sa", "designer"] }
        },
        "affected-modules": {
          "type": "array",
          "items": { "type": "string", "pattern": "^M-[0-9]{3,}$" }
        },
        "kpi": { "type": "object" },
        "locked-fields": { "type": "array" },
        "clarification-notes": { "type": "string" },
        "created": { "type": "string" },
        "last-updated": { "type": "string" },
        "output-mode": { "enum": ["lean", "full"] },
        "repo-type": { "enum": ["mini", "mono"] },
        "repo-path": { "type": "string" }
      }
    }
  }
}
