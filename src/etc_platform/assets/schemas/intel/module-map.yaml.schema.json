{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://etc-vn.github.io/schemas/intel/module-map.yaml.schema.json",
  "title": "Module path resolver",
  "description": "M-NNN → filesystem path mapping. Used by mcp__etc-platform__resolve_path. Per ADR-003 D9-4 (moved into intel/).",
  "type": "object",
  "required": ["schema_version", "modules"],
  "properties": {
    "schema_version": { "type": "string" },
    "modules": {
      "type": "object",
      "patternProperties": {
        "^M-[0-9]{3,}$": {
          "type": "object",
          "required": ["path", "slug"],
          "properties": {
            "name": { "type": "string" },
            "slug": { "type": "string", "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$" },
            "path": {
              "type": "string",
              "description": "Relative to workspace root, e.g. docs/modules/M-001-iam"
            }
          }
        }
      },
      "additionalProperties": false
    }
  }
}
